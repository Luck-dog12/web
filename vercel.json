{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "experimentalServices": {
    "web": {
      "entrypoint": "spec-kit-template-agy-ps-v0.1.5/apps/web",
      "routePrefix": "/",
      "framework": "nextjs"
    },
    "api": {
      "entrypoint": "spec-kit-template-agy-ps-v0.1.5/apps/api",
      "routePrefix": "/api",
      "framework": "nestjs",
      "includeFiles": [
        "spec-kit-template-agy-ps-v0.1.5/apps/api/src/generated/prisma/**/*",
        "spec-kit-template-agy-ps-v0.1.5/apps/api/node_modules/**/*",
        "spec-kit-template-agy-ps-v0.1.5/apps/api/dist/src/generated/prisma/**/*"
      ]
    }
  }
}
