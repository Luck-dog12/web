{
  "name": "spec-kit-template-agy-ps-v0.1.5",
  "version": "1.0.0",
  "description": "",
  "private": true,
  "main": "index.js",
  "scripts": {
    "dev": "concurrently -n web,api -c blue,green \"npm run dev -w apps/web\" \"npm run start:dev -w apps/api\"",
    "dev:web": "npm run dev -w apps/web",
    "dev:api": "npm run start:dev -w apps/api",
    "db:start": "docker compose up -d postgres",
    "db:stop": "docker compose down",
    "db:generate": "npm run prisma:generate -w apps/api",
    "db:migrate:dev": "npm run prisma:migrate:dev -w apps/api",
    "db:migrate:deploy": "npm run prisma:migrate:deploy -w apps/api",
    "db:studio": "npm run prisma:studio -w apps/api",
    "build": "npm run build -w apps/web && npm run build -w apps/api",
    "init:local-users": "npm run init:local-users -w apps/api",
    "lint": "npm run lint -w apps/web && npm run lint -w apps/api",
    "test": "npm run test -w apps/api",
    "test:e2e:checkout": "powershell -ExecutionPolicy Bypass -File ./scripts/run-checkout-playback-e2e.ps1 -RuntimeMode dev",
    "test:e2e:checkout:prod": "powershell -ExecutionPolicy Bypass -File ./scripts/run-checkout-playback-e2e.ps1 -RuntimeMode prod",
    "verify:p2-metrics": "node scripts/verify-p2-metrics.js"
  },
  "workspaces": [
    "apps/*"
  ],
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "devDependencies": {
    "concurrently": "^9.2.1"
  }
}
