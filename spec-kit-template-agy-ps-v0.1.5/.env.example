# Frontend and API origins
WEB_BASE_URL=http://localhost:3000
WEB_BASE_URLS=http://localhost:3000,http://127.0.0.1:3000
API_BASE_URL=http://localhost:3001

# Runtime basics
PORT=3001
SESSION_SECRET=dev-session-secret
SESSION_TTL_SECONDS=604800
SESSION_COOKIE_SECURE=

# Required database connections
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:5432/spec_kit?schema=public
DIRECT_URL=postgresql://postgres:postgres@127.0.0.1:5432/spec_kit?schema=public
DATABASE_POOL_MAX=10

# Required in production for Redis-backed sessions
REDIS_URL=

# Optional local bootstrap user (password is set via script, not stored here)
LOCAL_TEST_USER_EMAIL=

# Required PayPal variables
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
PAYPAL_BASE_URL=https://api-m.sandbox.paypal.com

# Optional PayPal hardening
PAYPAL_WEBHOOK_ID=

# Optional admin / geo controls
ADMIN_EMAILS=
ADMIN_USER_IDS=
BLOCKED_COUNTRIES=
SEED_DEMO_CATALOG_ON_BOOT=false
SEED_DEMO_STREAM_VIDEO_ID=

# Optional observability
SENTRY_DSN=
SENTRY_RELEASE=
NEXT_PUBLIC_SENTRY_DSN=

SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-or-publishable-key
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
# Course storefront / NestJS API base URL
NEXT_PUBLIC_APP_API_BASE_URL=http://localhost:3001
# Backward-compatible alias used by older pages
NEXT_PUBLIC_API_BASE_URL=http://localhost:3001
API_URL=
NEXT_PUBLIC_API_URL=
# Playwright defaults can target a dedicated local E2E web port
PLAYWRIGHT_BASE_URL=http://127.0.0.1:3400
# Supabase Edge Functions base URL for MVP flows
NEXT_PUBLIC_SUPABASE_FUNCTIONS_BASE_URL=https://your-project-ref.supabase.co/functions/v1
NEXT_PUBLIC_SUPABASE_FUNCTIONS_URL=
NEXT_PUBLIC_PAYPAL_CLIENT_ID=

# Cloudflare Stream integration
CF_STREAM_ACCOUNT_ID=
CF_STREAM_API_TOKEN=
CF_STREAM_CUSTOMER_CODE=customer-xxxxxxx
MCP_API_KEY=

